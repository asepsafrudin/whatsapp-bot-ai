# =============================================================================
# WhatsApp Bot AI (Baileys) — Environment Variables Template
# =============================================================================
# Copy file ini ke .env dan isi nilai yang sesuai.

# --- OpenAI / LLM Legacy (opsional, hanya untuk prompt LLM standalone) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
SYSTEM_PROMPT=Kamu adalah asisten WhatsApp yang ramah, singkat, dan membantu.
REPLY_TO_GROUPS=false

# --- Baileys Webhook Server ---
WEBHOOK_PORT=3001
WEBHOOK_HOST=http://localhost:3001

# --- FastAPI Orchestrator (ai-orchestrator) ---
FASTAPI_URL=http://localhost:8001/api/v1/chat
WEBHOOK_SECRET=mcp_unified_webhook_2026

# --- Send Queue (TASK-107) ---
WA_SEND_MIN_INTERVAL_MS=1500
WA_SEND_JITTER_MS=1200
# (REVIEW-FIX) Batas maksimal antrean; pesan baru ditolak bila penuh (anti-overflow saat outage)
WA_SEND_MAX_DEPTH=100

# --- Briefing Pagi (TASK-047 predecessor, dimigrasi di TASK-108) ---
# Format JSON untuk multiple target briefing.
# Contoh: [{"jid":"120363426109888899@g.us", "name":"Bagian PUU", "cron":"0 8 * * 1-5", "context":"Buat joke garing bertema pemrograman/database dan sisipkan fun tech thought of the day"}]
# BRIEFING_TARGETS='[{"jid":"120363426109888899@g.us", "name":"Bagian PUU", "cron":"0 8 * * 1-5", "context":"Buat joke garing bertema pemrograman/database dan sisipkan fun tech thought of the day"}]'

# Backward compatibility (jika BRIEFING_TARGETS tidak di-set):
BRIEFING_GROUP_JID=120363426109888899@g.us
BRIEFING_CRON=0 8 * * 1-5

# =============================================================================
# TASK-047 Fase 1a: Recent Conversation Memory
# =============================================================================
# Whitelist message retention (raw history, 30 hari default)
WHATSAPP_MEMORY_RECENT_LIMIT=10
WHATSAPP_MEMORY_RETENTION_DAYS=30

# Cron untuk purge memory yang sudah expired (default: tiap jam 03:00 WIB)
WHATSAPP_MEMORY_PURGE_CRON=0 3 * * *

# (Opsional) Override connection string PostgreSQL. Jika kosong, otomatis
# fallback ke DATABASE_URL, atau POSTGRES_HOST/POSTGRES_USER/.../POSTGRES_DB.
# WHATSAPP_MEMORY_DATABASE_URL=postgresql://user:pass@host:5432/dbname
